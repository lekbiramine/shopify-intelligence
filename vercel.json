{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/run-pipeline",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/app",
      "destination": "/api/index"
    },
    {
      "source": "/app/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/install",
      "destination": "/api/index"
    },
    {
      "source": "/oauth/install",
      "destination": "/api/index"
    },
    {
      "source": "/oauth/callback",
      "destination": "/api/index"
    },
    {
      "source": "/health",
      "destination": "/api/index"
    },
    {
      "source": "/healthz",
      "destination": "/api/index"
    },
    {
      "source": "/unsubscribe",
      "destination": "/api/index"
    },
    {
      "source": "/api/cron/run-pipeline",
      "destination": "/api/index"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/index"
    }
  ]
}
